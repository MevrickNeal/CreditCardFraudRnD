    {
      "cell_type": "code",
      "source": [
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))\n",
        "\n",
        "# 1. ROC Curve\n",
        "fpr, tpr, _ = roc_curve(y_test, y_probs)\n",
        "ax1.plot(fpr, tpr, color='#2563eb', lw=3, label=f'ROC Curve (AUC = {roc_auc_score(y_test, y_probs):.3f})')\n",
        "ax1.plot([0, 1], [0, 1], color='#94a3b8', linestyle='--')\n",
        "ax1.set_title(\"Receiver Operating Characteristic (Hybrid Performance)\")\n",
        "ax1.legend(loc=\"lower right\")\n",
        "\n",
        "# 2. Confusion Matrix\n",
        "cm = confusion_matrix(y_test, y_pred)\n",
        "disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=['Legitimate', 'Fraud'])\n",
        "disp.plot(cmap='Blues', ax=ax2)\n",
        "ax2.set_title(\"Confusion Matrix (Real Employee Data)\")\n",
        "ax2.grid(False)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n--- Detailed Classification Report ---\")\n",
        "print(classification_report(y_test, y_pred))"
      ],
      "metadata": {
